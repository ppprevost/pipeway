{
  "name": "pipeway-next",
  "version": "0.1.0",
  "description": "A typed pipeline for Next.js server actions — compile-time step ordering, Result-first ActionResult, Standard Schema input validation.",
  "keywords": [
    "pipeway",
    "next",
    "server-actions",
    "next.js",
    "action",
    "standard-schema"
  ],
  "license": "MIT",
  "author": "Pierre-Philippe Prévost",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ppprevost/pipeway.git",
    "directory": "packages/next"
  },
  "homepage": "https://ppprevost.github.io/pipeway",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@standard-schema/spec": "^1.0.0"
  },
  "devDependencies": {
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "zod": "^3.24.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
