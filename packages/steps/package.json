{
  "name": "pipeway-steps",
  "version": "0.2.0",
  "description": "Generic validation steps for pipeway (body, query) — Standard Schema: works with Zod, Valibot, ArkType.",
  "keywords": [
    "pipeway",
    "standard-schema",
    "zod",
    "valibot",
    "arktype",
    "validation",
    "middleware"
  ],
  "license": "MIT",
  "author": "Pierre-Philippe Prévost",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ppprevost/pipeway.git",
    "directory": "packages/steps"
  },
  "homepage": "https://ppprevost.github.io/pipeway",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@standard-schema/spec": "^1.0.0"
  },
  "peerDependencies": {
    "pipeway": "workspace:*"
  },
  "devDependencies": {
    "pipeway": "workspace:*",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "valibot": "^1.0.0",
    "zod": "^3.24.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
