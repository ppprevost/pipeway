{
  "name": "pipeway-react",
  "version": "0.0.0",
  "description": "React hooks for pipeway-client — useQuery / useMutation, Result-first, zero deps beyond React.",
  "keywords": ["pipeway", "react", "hooks", "usequery", "usemutation", "fetch"],
  "license": "MIT",
  "author": "Pierre-Philippe Prévost",
  "repository": { "type": "git", "url": "git+https://github.com/ppprevost/pipeway.git", "directory": "packages/react" },
  "homepage": "https://ppprevost.github.io/pipeway",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "pipeway-client": "workspace:*",
    "react": ">=18"
  },
  "devDependencies": {
    "pipeway-client": "workspace:*",
    "@testing-library/react": "^16.0.0",
    "@types/react": "^18.3.0",
    "jsdom": "^25.0.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0"
  },
  "publishConfig": { "access": "public" }
}
